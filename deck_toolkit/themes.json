{
  "_comment": "House-style palettes for the survival_minicourse deck toolkit. Single source of truth, read by both deck_lib.js and render_assets.py. To add M31 brand colors, copy a block, rename it, and replace the hex values (no '#').",
  "_fields": {
    "primary": "dominant dark — title-slide/divider backgrounds, headings, table headers, code background",
    "accent": "main accent — kickers, accent bars, numbers, arrows",
    "accentDark": "darker accent — emphasized/takeaway text, callout titles",
    "body": "default body text",
    "muted": "captions, footers, secondary notes",
    "light": "light panel/card fill",
    "line": "card/table borders",
    "codeBg": "code panel background (usually = primary)",
    "codeFg": "code foreground text",
    "codeComment": "code comments (a light tint of accent)",
    "white": "page background for content slides",
    "headFont": "heading font", "bodyFont": "body font", "monoFont": "any native monospace text"
  },

